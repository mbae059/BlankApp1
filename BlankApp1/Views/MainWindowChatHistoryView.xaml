<UserControl x:Class="BlankApp1.Views.MainWindowChatHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BlankApp1.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="15" VerticalAlignment="Bottom">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Profile Circle with Initial -->
                            <Grid Grid.Column="0" VerticalAlignment="Top" Margin="0,2,12,0">
                                <Ellipse Width="40" Height="40" Fill="#5865F2"/>
                                <TextBlock Text="{Binding User[0]}" 
                                           Foreground="White" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           FontWeight="Bold"
                                           FontSize="16"/>
                            </Grid>
                            
                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                    <TextBox Text="{Binding User, Mode=OneWay}" 
                                             FontWeight="Bold" 
                                             FontSize="16"
                                             Foreground="#FFFFFF"
                                             IsReadOnly="True" 
                                             Background="Transparent" 
                                             BorderThickness="0"
                                             Padding="0"
                                             Cursor="IBeam"
                                             IsReadOnlyCaretVisible="False"
                                             SelectionBrush="#5865F2"
                                             Focusable="True"/>
                                    
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}" 
                                               Foreground="#949BA4" 
                                               FontSize="12" 
                                               VerticalAlignment="Bottom" 
                                               Margin="8,0,0,2"/>
                                </StackPanel>

                                <TextBox Text="{Binding Message, Mode=OneWay}" 
                                         Foreground="#DBDEE1" 
                                         FontSize="15"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True" 
                                         Background="Transparent" 
                                         BorderThickness="0"
                                         Padding="0"
                                         Cursor="IBeam"
                                         IsReadOnlyCaretVisible="False"
                                         SelectionBrush="#5865F2"
                                         Focusable="True"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
