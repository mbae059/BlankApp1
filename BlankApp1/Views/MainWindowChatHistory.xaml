<UserControl x:Class="BlankApp1.Views.MainWindowChatHistory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BlankApp1.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="20" VerticalAlignment="Bottom">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Margin="0,5">
                            <TextBlock Text="{Binding User}" 
                           FontWeight="Bold" 
                           Foreground="#FFFFFF"/>

                            <TextBox Text="{Binding Message, Mode=OneWay}" 
                         Foreground="#DBDEE1" 
                         TextWrapping="Wrap"
                         IsReadOnly="True" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Padding="0"
                         Margin="0,2,0,0"
                         Cursor="IBeam"
                         IsReadOnlyCaretVisible="False"
                         SelectionBrush="#5865F2"
                         Focusable="True"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
