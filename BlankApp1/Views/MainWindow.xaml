<Window x:Class="BlankApp1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="850" Width="1375" >

    <StackPanel>
        <TextBlock Text="Hello, World!" FontSize="24" HorizontalAlignment="Center" Margin="10"/>
        <Button Content="Click Me" Width="100" Height="30" HorizontalAlignment="Center" Margin="10" Command="{Binding ChangeTitleCommand}"/>

        <CheckBox Content="Allow Button to work" IsChecked="{Binding IsActionEnabled}"/>
        <Button Content="Click Me" Command="{Binding ClickMeCommand}" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
