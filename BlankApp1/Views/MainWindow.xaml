<Window x:Class="BlankApp1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}" Height="850" Width="1375" >

    <Grid Background="#1E1F22">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0" prism:RegionManager.RegionName="ServerListRegion" />
        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="DMListRegion" />
        <ContentControl Grid.Column="2" prism:RegionManager.RegionName="ChatRegion" />
    </Grid>
</Window>
