<UserControl x:Class="BlankApp1.Views.MainWindowChat"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Background="#313338">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding HeaderMessage}" 
                       Foreground="White" 
                       FontSize="24" 
                       FontWeight="Bold"/>

            <Separator Background="#3F4147" Margin="0,10"/>

            <TextBlock Text="Welcome to the beginning of the channel." 
                       Foreground="#B5BAC1" 
                       Margin="0,20"/>
        </StackPanel>
    </Grid>
</UserControl>