<UserControl x:Class="BlankApp1.Views.Authentication.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BlankApp1.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#313338">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Welcome back!" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="We're so excited to see you again!" Foreground="#B5BAC1" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="USERNAME" Foreground="#B5BAC1" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                 Background="#1E1F22" Foreground="White" BorderThickness="0" Padding="10" Margin="0,0,0,20"/>

            <Button Content="Log In" 
                Command="{Binding LoginCommand}"
                Background="#5865F2" Foreground="#6005F2" Height="45" FontWeight="Bold" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="3"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
